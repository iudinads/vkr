POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vkr_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
# Сгенерировать локально: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-generated-secret-key
DEBUG=False
# Ключ DeepSeek берется из кабинета провайдера (https://platform.deepseek.com/)
DEEPSEEK_API_KEY=replace-with-your-deepseek-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
MAIL_SERVER=smtp.yandex.ru
MAIL_PORT=465
MAIL_USE_SSL=True
MAIL_USERNAME=your-email@yandex.ru
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@yandex.ru
